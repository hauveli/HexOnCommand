{
	"schemaVersion": 1,
	"id": "hexoncommand",
	"version": "${version}",
	"name": "hexoncommand",
	"description": "This mod registers a single command /hexcastinggui and one attribute hexoncommand:command_permission.",
	"authors": [
		"hauveli"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/hexoncommand/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "hauveli.hexoncommand.HexOnCommand",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "hauveli.hexoncommand.HexOnCommandClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "hauveli.hexoncommand.HexOnCommandDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
      "hexoncommand.mixins.json",
		{
			"config": "hexoncommand.client.mixins.json",
			"environment": "client"
		},
		{
			"config": "hexoncommand.mixins.json",
			"environment": "server"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}